# Supabase
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key   # サーバーサイドのみ使用

# App
NEXT_PUBLIC_APP_URL=http://localhost:3000
NEXT_PUBLIC_AUTH_REDIRECT_PATH=/dashboard

# -------------------------------------------------------
# 開発・テスト専用フラグ
# 'true' にすると提出期限・承認禁止期間のチェックをすべて無効化する。
# 本番環境では設定しないこと（未設定 or 'false' で通常動作）。
# -------------------------------------------------------
NEXT_PUBLIC_BYPASS_DEADLINE=false

# -------------------------------------------------------
# デモログイン（ポートフォリオ閲覧用）
# ?demo=true パラメータ付きのログイン画面でのみ使用されます。
# Supabase 上に作成したデモアカウントの認証情報を設定してください。
# -------------------------------------------------------
NEXT_PUBLIC_DEMO_ADMIN_EMAIL=demo-admin@example.com
NEXT_PUBLIC_DEMO_ADMIN_PASSWORD=your-demo-admin-password
NEXT_PUBLIC_DEMO_STAFF_EMAIL=demo-staff@example.com
NEXT_PUBLIC_DEMO_STAFF_PASSWORD=your-demo-staff-password
